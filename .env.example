# Copy this file to `.env` and fill in your own values:
#   cp .env.example .env

# Jackett API key — found at the top-right of the Jackett UI (http://localhost:9117)
JACKETT_API_KEY=your_jackett_api_key_here

# Where downloads land on your machine (created automatically if missing)
DOWNLOADS_PATH=~/Downloads/torrents

# qBittorrent Web UI credentials.
# On first launch the linuxserver image prints a temporary password in the logs
# (`docker compose logs qbittorrent | grep password`). Set a permanent one in
# the Web UI (Tools → Options → Web UI) and put it here.
QBIT_USER=admin
QBIT_PASS=changeme
